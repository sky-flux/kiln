# Copy to .env for production deployment.  .env is gitignored.
# docker compose automatically reads .env from the repo root — no flag needed.

# --- Image built by `./gradlew :app:bootBuildImage` ---
#     The default tag is `docker.io/library/app:<version>`; use the full tag here.
APP_IMAGE=app:0.0.1-SNAPSHOT
APP_PORT=8080

# --- Postgres credentials (also feed the app's DB_* env vars via compose.prod.yml) ---
POSTGRES_DB=kiln
POSTGRES_USER=kiln
POSTGRES_PASSWORD=change-me-before-deploying

# --- CORS (application-prod.yml requires this; fail-fast if missing) ---
CORS_ALLOWED_ORIGIN=https://your-domain.example.com
