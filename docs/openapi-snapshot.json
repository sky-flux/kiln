  "components" : {
    "schemas" : {
      "UpdateUserRequest" : {
        "type" : "object",
        "properties" : {
          "name" : {
            "type" : "string",
            "maxLength" : 100,
            "minLength" : 0
          }
        }
      },
      "RUserResponse" : {
        "type" : "object",
        "properties" : {
          "code" : {
            "type" : "integer",
            "format" : "int32"
          },
          "message" : {
            "type" : "string"
          },
          "data" : {
            "$ref" : "#/components/schemas/UserResponse"
          },
          "timestamp" : {
            "type" : "string",
            "format" : "date-time"
          }
        }
      },
      "UserResponse" : {
        "type" : "object",
        "properties" : {
          "id" : {
            "type" : "string"
          },
          "name" : {
            "type" : "string"
          },
          "email" : {
            "type" : "string"
          },
          "status" : {
            "type" : "string"
          }
        }
      },
      "UpdateProductRequest" : {
        "type" : "object",
        "properties" : {
          "name" : {
            "type" : "string",
            "maxLength" : 200,
            "minLength" : 0
          },
          "description" : {
            "type" : "string"
          },
          "priceAmount" : {
            "type" : "number",
            "minimum" : 0
          },
          "priceCurrency" : {
            "type" : "string",
            "maxLength" : 3,
            "minLength" : 0
          }
        },
        "required" : [ "priceAmount" ]
      },
      "ProductResponse" : {
        "type" : "object",
        "properties" : {
          "id" : {
            "type" : "string"
          },
          "code" : {
            "type" : "string"
          },
          "name" : {
            "type" : "string"
          },
          "description" : {
            "type" : "string"
          },
          "priceAmount" : {
            "type" : "number"
          },
          "priceCurrency" : {
            "type" : "string"
          },
          "status" : {
            "type" : "string"
          }
        }
      },
      "RProductResponse" : {
        "type" : "object",
        "properties" : {
          "code" : {
            "type" : "integer",
            "format" : "int32"
          },
